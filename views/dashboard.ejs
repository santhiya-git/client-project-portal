<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Client Project Portal</title>

    <link rel="stylesheet" href="/css/dashboard.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

<div class="sidebar">

<div class="logo">
<h2>🏢 Client Portal</h2>
</div>

<ul>

<li><a href="/dashboard"><i class="fa-solid fa-house"></i> Dashboard</a></li>

<li><a href="/projects"><i class="fa-solid fa-folder-open"></i> Projects</a></li>

<li><a href="/addProject"><i class="fa-solid fa-circle-plus"></i> Add Project</a></li>

<li><a href="#"><i class="fa-solid fa-calendar"></i> Milestones</a></li>

<li><a href="#"><i class="fa-solid fa-file-lines"></i> Documents</a></li>

<li><a href="#"><i class="fa-solid fa-chart-line"></i> Reports</a></li>

<li><a href="/"><i class="fa-solid fa-right-from-bracket"></i> Logout</a></li>

</ul>

</div>

<div class="main">

<div class="topbar">

<h1>Dashboard</h1>

<div class="right">

<input
type="text"
placeholder="Search Project">

<div class="profile">

<i class="fa-solid fa-user"></i>

<span>Admin</span>

</div>

</div>

</div>

<div class="cards">

<div class="card blue">

<i class="fa-solid fa-folder"></i>

<h2><%= totalProjects %></h2>

<p>Total Projects</p>

</div>

<div class="card green">

<i class="fa-solid fa-circle-check"></i>

<h2><%= completedProjects %></h2>

<p>Completed</p>

</div>

<div class="card orange">

<i class="fa-solid fa-spinner"></i>

<h2><%= ongoingProjects %></h2>

<p>Ongoing</p>

</div>

<div class="card purple">

<i class="fa-solid fa-lightbulb"></i>

<h2><%= planningProjects %></h2>

<p>Planning</p>

</div>

</div>

<div class="content">

<div class="recent">

<h2>Recent Projects</h2>

<table>

<tr>

<th>Project</th>

<th>Client</th>

<th>Status</th>

</tr>

<% recentProjects.forEach(project => { %>

<tr>

<td><%= project.project_name %></td>

<td><%= project.client_name %></td>

<td>

<span class="status
<%= project.status.toLowerCase() %>">

<%= project.status %>

</span>

</td>

</tr>

<% }) %>

</table>

</div>
<div class="right-panel">

    <div class="progress-box">

        <h2>Project Progress</h2>

        <p>Total Completion</p>

        <div class="progress">

            <div class="progress-fill">
                80%
            </div>

        </div>

    </div>

    <div class="notification-box">

        <h2>Recent Notifications</h2>

        <div class="note">
            🎉 Welcome to Client Project Portal
        </div>

        <div class="note">
            📁 Dashboard connected successfully
        </div>

        <div class="note">
            📊 Statistics loaded from MySQL
        </div>

    </div>

</div>

</div>

<!-- Charts -->

<div class="charts">

    <div class="chart-card">

        <h2>Project Status</h2>

        <canvas id="statusChart"></canvas>

    </div>

    <div class="chart-card">

        <h2>Monthly Projects</h2>

        <canvas id="monthChart"></canvas>

    </div>

</div>

</div>

<script src="/js/dashboard.js"></script>

</body>

</html>